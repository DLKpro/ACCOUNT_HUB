{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AccountHub",
  "version": "0.0.1",
  "identifier": "ca.dlopro.accounthub",
  "build": {
    "beforeDevCommand": "npm --prefix ./web run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm --prefix ./web run build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "AccountHub",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:3000 http://localhost:3000",
      "freezePrototype": true
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
