{
  "name": "accounthub",
  "private": true,
  "version": "0.0.1",
  "description": "ACCOUNT_HUB desktop workspace root — delegates to web/ for frontend scripts and to @tauri-apps/cli for the Tauri shell.",
  "scripts": {
    "frontend:dev": "npm --prefix web run dev",
    "frontend:build": "npm --prefix web run build",
    "frontend:install": "npm --prefix web install",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --config ./crates/gui/tauri.conf.json",
    "tauri:build": "tauri build --config ./crates/gui/tauri.conf.json",
    "tauri:icon": "tauri icon"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0"
  }
}
